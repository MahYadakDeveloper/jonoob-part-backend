{
  "scripts": {
    "prisma:gen": "pnpm --filter @infra/database exec prisma generate",
    "prisma:mig:dev": "pnpm --filter @infra/database exec prisma migrate dev",
    "start:dev": "concurrently -k \" pnpm --filter @app/api exec nest start --watch\"  \"pnpm --parallel -r --filter @app/api^... dev \" ",
    "dev": "concurrently -n \"packages,api\" -c \"cyan,green\" \"pnpm -r --parallel --filter=!./apps/api run dev\" \"pnpm --filter ./apps/api exec nest start --watch\"",
    "start:dev:api": "pnpm --filter @app/api exec nest start --watch",
    "start:dev:deps": "pnpm --parallel -r --filter @app/api^... dev",
    "start:build:deps": "pnpm --parallel -r --filter @app/api^... build",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "typescript-eslint": "^8.61.1"
  }
}
